        .controls { display: flex; justify-content: center; gap: 15px; margin-top: 25px; flex-wrap: wrap; }
        .btn { background: transparent; border: 1px solid var(--charcoal); padding: 12px 30px; font-family: 'Cinzel', serif; font-size: 0.7rem; letter-spacing: 3px; text-transform: uppercase; cursor: pointer; transition: all 0.3s ease; position: relative; overflow: hidden; color: var(--charcoal); }
        .btn::before { content: ''; position: absolute; top: 0; left: -100%; width: 100%; height: 100%; background: var(--charcoal); transition: left 0.3s ease; z-index: -1; }
        .btn:hover::before { left: 0; } .btn:hover { color: var(--cream); }
        .shutter-btn { width: 70px; height: 70px; border-radius: 50%; border: 2px solid var(--charcoal); background: linear-gradient(145deg, #8B4513 0%, #654321 50%, #4A3018 100%); position: relative; padding: 0; box-shadow: inset 0 2px 4px rgba(255,255,255,0.2), inset 0 -2px 4px rgba(0,0,0,0.3), 0 4px 8px rgba(0,0,0,0.3); }
        .shutter-btn::before { content: ''; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 52px; height: 52px; border-radius: 50%; border: 1px solid rgba(0,0,0,0.25); background: linear-gradient(145deg, #A0522D 0%, #8B4513 100%); box-shadow: inset 0 1px 2px rgba(255,255,255,0.15); }
        .shutter-btn:hover { transform: scale(1.05); } .shutter-btn:active { transform: scale(0.95); }
        .gallery-section { margin-top: 40px; text-align: center; }
