        .camera-container { position: relative; width: 100%; max-width: 450px; margin: 0 auto; aspect-ratio: 4/3; background: var(--film-black); border: 6px solid var(--film-black); overflow: hidden; box-shadow: 0 0 0 1px var(--charcoal), 0 0 0 2px var(--cream), 0 0 0 3px var(--charcoal), 0 10px 30px rgba(0,0,0,0.25); }
