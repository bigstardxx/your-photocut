        &lt;section class="filter-section"&gt;
            &lt;h2 class="section-title"&gt;Aesthetic&lt;/h2&gt;
            &lt;div class="filter-grid"&gt;
                &lt;button class="filter-btn active" data-style="film"&gt;&lt;span style="font-family: 'Cinzel', serif;"&gt;菲林&lt;/span&gt; — Film&lt;/button&gt;
                &lt;button class="filter-btn" data-style="dreamy"&gt;&lt;span style="font-family: 'Cinzel', serif;"&gt;梦核&lt;/span&gt; — Dreamcore&lt;/button&gt;
                &lt;button class="filter-btn" data-style="y2k"&gt;&lt;span style="font-family: 'Cinzel', serif;"&gt;千禧&lt;/span&gt; — Y2K&lt;/button&gt;
            &lt;/div&gt;
        &lt;/section&gt;
        &lt;section class="camera-section"&gt;
            &lt;div class="camera-container"&gt;
                &lt;video id="video" autoplay playsinline&gt;&lt;/video&gt;
                &lt;canvas id="canvas"&gt;&lt;/canvas&gt;
                &lt;div class="camera-frame"&gt;&lt;/div&gt;
                &lt;div class="camera-corner top-left"&gt;&lt;/div&gt;&lt;div class="camera-corner top-right"&gt;&lt;/div&gt;&lt;div class="camera-corner bottom-left"&gt;&lt;/div&gt;&lt;div class="camera-corner bottom-right"&gt;&lt;/div&gt;
                &lt;div class="countdown" id="countdown"&gt;3&lt;/div&gt;
                &lt;div class="camera-overlay"&gt;&lt;div class="camera-status"&gt;~ Rec ~&lt;/div&gt;&lt;div class="camera-status" id="frames-left"&gt;&lt;/div&gt;&lt;/div&gt;
            &lt;/div&gt;
            &lt;div class="controls"&gt;&lt;button class="btn" id="start-camera"&gt;Initialize&lt;/button&gt;&lt;button class="shutter-btn hidden" id="capture-btn"&gt;&lt;/button&gt;&lt;/div&gt;
        &lt;/section&gt;
        &lt;section class="gallery-section hidden" id="gallery-section"&gt;
            &lt;h2 class="section-title"&gt;Memories&lt;/h2&gt;
            &lt;div class="gallery" id="gallery"&gt;&lt;/div&gt;
        &lt;/section&gt;
    &lt;/div&gt;
        function addPhotoToGallery(styledImageSrc, style, mode) {
            gallerySection.classList.remove('hidden');
            const index = capturedPhotos.length; capturedPhotos.push(styledImageSrc);
            const item = document.createElement('div'); item.className = 'photo-item ' + style; item.onclick = () =&gt; openLightbox(index);
            if (style === 'film') {
                const scratches = document.createElement('div'); scratches.className = 'film-scratches'; item.appendChild(scratches);
                const leak = document.createElement('div'); leak.className = 'film-light-leak'; item.appendChild(leak);
                const markings = document.createElement('div'); markings.className = 'film-markings'; markings.innerHTML = '&lt;span&gt;KODAK&lt;/span&gt;&lt;span&gt;35mm&lt;/span&gt;'; item.appendChild(markings);
            } else if (style === 'dreamy') {
                ['r1', 'r2', 'r3'].forEach(cls =&gt; { const r = document.createElement('div'); r.className = 'dreamy-light-ray ' + cls; item.appendChild(r); });
                ['b1', 'b2', 'b3', 'b4'].forEach(cls =&gt; { const b = document.createElement('span'); b.className = 'dreamy-butterfly ' + cls; b.textContent = '🦋'; item.appendChild(b); });
                ['s1', 's2', 's3', 's4', 's5'].forEach(cls =&gt; { const s = document.createElement('span'); s.className = 'dreamy-sparkle ' + cls; item.appendChild(s); });
                ['c1', 'c2', 'c3'].forEach(cls =&gt; { const c = document.createElement('div'); c.className = 'dreamy-cloud ' + cls; item.appendChild(c); });
                const grain = document.createElement('div'); grain.className = 'dreamy-grain'; item.appendChild(grain);
            } else if (style === 'y2k') {
                const titlebar = document.createElement('div'); titlebar.className = 'y2k-titlebar'; titlebar.innerHTML = '&lt;span class="y2k-title"&gt;Photo.exe&lt;/span&gt;&lt;div class="y2k-buttons"&gt;&lt;span class="y2k-btn"&gt;_&lt;/span&gt;&lt;span class="y2k-btn"&gt;□&lt;/span&gt;&lt;span class="y2k-btn"&gt;×&lt;/span&gt;&lt;/div&gt;'; item.appendChild(titlebar);
                const content = document.createElement('div'); content.className = 'y2k-content';
                ['h1', 'h2', 'h3'].forEach(cls =&gt; { const h = document.createElement('span'); h.className = 'y2k-pixel-heart ' + cls; h.textContent = '♥'; content.appendChild(h); });
                ['i1', 'i2'].forEach(cls =&gt; { const ic = document.createElement('div'); ic.className = 'y2k-icon ' + cls; ic.textContent = '▼'; content.appendChild(ic); });
                ['e1', 'e2'].forEach(cls =&gt; { const e = document.createElement('span'); e.className = 'y2k-emoticon ' + cls; e.textContent = cls === 'e1' ? ':-)' : ';-)'; content.appendChild(e); });
                const img = document.createElement('img'); img.src = styledImageSrc; content.appendChild(img); item.appendChild(content);
            }
            if (style !== 'y2k') { const img = document.createElement('img'); img.src = styledImageSrc; item.appendChild(img); }
            gallery.insertBefore(item, gallery.firstChild);
        }

        function openLightbox(index) { currentLightboxIndex = index; lightboxImg.src = capturedPhotos[index]; lightbox.classList.add('active'); }
        function closeLightbox() { lightbox.classList.remove('active'); currentLightboxIndex = -1; }
        function downloadFromLightbox() { if (currentLightboxIndex &gt;= 0) { const link = document.createElement('a'); link.download = 'ethereal-' + Date.now() + '.jpg'; link.href = capturedPhotos[currentLightboxIndex]; link.click(); } }
        lightbox.addEventListener('click', (e) =&gt; { if (e.target === lightbox) closeLightbox(); });
        function resetCapture() { life4CutPhotos = []; framesLeftEl.textContent = ''; }
        function sleep(ms) { return new Promise(resolve =&gt; setTimeout(resolve, ms)); }
    &lt;/script&gt;
&lt;/body&gt;
